# Supabase — client (public) keys. App falls back to bundled seed data when these are absent.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Supabase — server-only service role key. Used by the seed script (scripts/seed/mealfit.ts). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Public site URL — used for OG/Twitter metadata absolute URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Path to the source Excel workbook for the seed script.
MEALFIT_XLSX_PATH="docs/Meal Prep quản lý bán hàng final_sheet.xlsx"
